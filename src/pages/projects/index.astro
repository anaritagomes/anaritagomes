---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const base = import.meta.env.BASE_URL;
---

<Base title="Projects — Ana Rita Gomes" description="Case studies in documentation systems, automation pipelines, and knowledge governance.">
  <div class="py-20">
    <header class="mb-16 max-w-[70ch]">
      <p class="font-mono text-[#7B35E4] text-xs uppercase tracking-widest mb-4">Work</p>
      <h1 class="text-3xl font-semibold text-[#e8e8f0] mb-4">Projects</h1>
      <p class="text-[#6b6b80]">
        Selected case studies across automation engineering, documentation governance, and knowledge system design.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((p) => (
        <a
          href={`${base}/projects/${p.id}`}
          class="block border border-[#1e1e2a] p-7 hover:border-[#7B35E4]/40 transition-colors group no-underline"
        >
          {p.data.featured && (
            <p class="font-mono text-xs text-[#7B35E4] uppercase tracking-widest mb-3">Featured</p>
          )}
          <h2 class="text-[#e8e8f0] font-medium text-base mb-3 group-hover:text-[#7B35E4] transition-colors leading-snug">
            {p.data.title}
          </h2>
          <p class="text-[#6b6b80] text-sm leading-relaxed mb-5">{p.data.description}</p>
          <div class="flex gap-2 flex-wrap">
            {p.data.tags.map((t) => (
              <span class="font-mono text-xs text-[#6b6b80] border border-[#1e1e2a] px-2 py-0.5">{t}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
