---
import Base from '../layouts/Base.astro';
---

<Base title="CV — Ana Rita Gomes" description="CV and professional background of Ana Rita Gomes.">
  <div class="py-20 max-w-[70ch]">
    <header class="mb-16">
      <p class="font-mono text-[#c0392b] text-xs uppercase tracking-widest mb-4">Curriculum Vitae</p>
      <h1 class="text-3xl font-semibold text-[#e8e8f0] mb-4">Ana Rita Gomes</h1>
      <p class="text-[#6b6b80] mb-8">
        Knowledge Architect · Technical Writer · Former Software Engineer
      </p>
      <a
        href="/cv.pdf"
        download
        class="inline-flex items-center gap-2 bg-[#c0392b] text-[#e8e8f0] text-sm font-medium px-5 py-2.5 hover:bg-[#8b2b20] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download PDF
      </a>
    </header>

    <section class="mb-14">
      <h2 class="font-mono text-xs uppercase tracking-widest text-[#6b6b80] mb-6">Current</h2>
      <div class="border-l border-[#1e1e2a] pl-6">
        <div class="mb-6">
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Technical Writer → Knowledge Architect</h3>
            <span class="font-mono text-xs text-[#6b6b80]">2022 — present</span>
          </div>
          <p class="text-[#c0392b] text-sm mb-3">Constellation Automotive Group · Remote, Portugal</p>
          <ul class="text-[#6b6b80] text-sm space-y-2 list-none">
            <li>Managing a ~2,000-article knowledge base across 10 products in Helpjuice</li>
            <li>Built Azure DevOps-to-Helpjuice REST API automation pipeline in Python + Power Automate, reducing release note production time significantly</li>
            <li>Designed and leading a Minimum Viable Governance (MVG) documentation framework across the organisation</li>
            <li>Presented Knowledge Architecture positioning to Heads-level leadership</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="font-mono text-xs uppercase tracking-widest text-[#6b6b80] mb-6">Previous roles</h2>
      <div class="border-l border-[#1e1e2a] pl-6 flex flex-col gap-8">
        <div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Freelance Technical Writer</h3>
            <span class="font-mono text-xs text-[#6b6b80]">2021 — 2022</span>
          </div>
          <p class="text-[#c0392b] text-sm mb-2">We Are Volt</p>
          <p class="text-[#6b6b80] text-sm">Engineering management and leadership content.</p>
        </div>
        <div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Research Engineer</h3>
            <span class="font-mono text-xs text-[#6b6b80]">2019 — 2021</span>
          </div>
          <p class="text-[#c0392b] text-sm mb-2">Forschungszentrum Jülich · Germany</p>
          <p class="text-[#6b6b80] text-sm">Applied AI research in a scientific computing environment.</p>
        </div>
        <div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Software Engineer</h3>
            <span class="font-mono text-xs text-[#6b6b80]">2011 — 2019</span>
          </div>
          <p class="text-[#c0392b] text-sm mb-2">Altice Labs · PrimeIT · i2S/Cleva</p>
          <p class="text-[#6b6b80] text-sm">~8 years across telecoms, software consultancy, and healthcare IT.</p>
        </div>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="font-mono text-xs uppercase tracking-widest text-[#6b6b80] mb-6">Education</h2>
      <div class="border-l border-[#1e1e2a] pl-6 flex flex-col gap-6">
        <div>
          <h3 class="text-[#e8e8f0] font-medium mb-1">MSc Artificial Intelligence</h3>
          <p class="text-[#c0392b] text-sm mb-1">University of Leeds</p>
          <p class="text-[#6b6b80] text-sm">Thesis: hierarchical recurrent neural networks applied to speech processing.</p>
        </div>
        <div>
          <h3 class="text-[#e8e8f0] font-medium mb-1">Post-Graduate Certificate in Data Science</h3>
          <p class="text-[#c0392b] text-sm">Atlântica</p>
        </div>
        <div>
          <h3 class="text-[#e8e8f0] font-medium mb-1">BSc Information Technology</h3>
          <p class="text-[#c0392b] text-sm">Universidade de Aveiro</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-mono text-xs uppercase tracking-widest text-[#6b6b80] mb-6">Skills</h2>
      <div class="grid grid-cols-2 gap-6">
        <div>
          <h3 class="text-[#e8e8f0] text-sm font-medium mb-3">Documentation & Knowledge</h3>
          <ul class="text-[#6b6b80] text-sm space-y-1">
            <li>Docs-as-code (Docusaurus, MkDocs)</li>
            <li>Helpjuice, Confluence</li>
            <li>Content governance frameworks</li>
            <li>Information architecture</li>
          </ul>
        </div>
        <div>
          <h3 class="text-[#e8e8f0] text-sm font-medium mb-3">Engineering & Automation</h3>
          <ul class="text-[#6b6b80] text-sm space-y-1">
            <li>Python, REST APIs</li>
            <li>Power Automate, Azure DevOps</li>
            <li>Git, CI/CD pipelines</li>
            <li>SQL, data analysis</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</Base>
