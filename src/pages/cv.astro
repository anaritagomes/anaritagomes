---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="CV — Ana Rita Gomes" description="CV and professional background of Ana Rita Gomes.">
  <div class="py-20 max-w-[70ch]">
    <header class="mb-16">
      <p class="font-mono text-[#7B35E4] text-xs uppercase tracking-widest mb-4">Curriculum Vitae</p>
      <h1 class="text-3xl font-semibold text-[#e8e8f0] mb-4">Ana Rita Gomes</h1>
      <p class="text-[#6b6b80] mb-8">
        Knowledge Architect · Technical Writer · Former Software Engineer
      </p>
      <a
        href={`${base}/cv.pdf`}
        download
        class="inline-flex items-center gap-2 bg-[#7B35E4] text-[#e8e8f0] text-sm font-medium px-5 py-2.5 hover:bg-[#5a24a8] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download PDF
      </a>
    </header>

    <section class="mb-14">
      <h2 class="font-mono text-xs uppercase tracking-widest text-[#6b6b80] mb-6">Current</h2>
      <div class="border-l border-[#1e1e2a] pl-6">
        <div class="mb-6">
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Technical Writer → Knowledge Architect</h3>
            <span class="font-mono text-xs text-[#6b6b80]">Mar 2025 — present</span>
          </div>
          <p class="text-[#7B35E4] text-sm mb-3">Constellation Automotive Group · Remote, Portugal</p>
          <ul class="text-[#6b6b80] text-sm space-y-2 list-none">
            <li>Managing a ~2,000-article knowledge base across 10 products in Helpjuice</li>
            <li>Built an end-to-end automation pipeline (Python, Power Automate, Azure DevOps + Helpjuice APIs) that eliminated 20+ hours of weekly manual effort across 10 products, reducing release-to-documentation lag from days to zero</li>
            <li>Designed and leading a Minimum Viable Governance (MVG) documentation framework across the organisation</li>
            <li>Presented Knowledge Architecture positioning to Heads-level leadership</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="font-mono text-xs uppercase tracking-widest text-[#6b6b80] mb-6">Previous roles</h2>
      <div class="border-l border-[#1e1e2a] pl-6 flex flex-col gap-8">
        <div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Tech Lead · Full Stack Software Engineer</h3>
            <span class="font-mono text-xs text-[#6b6b80]">2020 — 2024</span>
          </div>
          <p class="text-[#7B35E4] text-sm mb-3">Forschungszentrum Jülich · Germany</p>
          <ul class="text-[#6b6b80] text-sm space-y-2 list-none">
            <li>Built a data processing platform for atmospheric research data from the ground up using Python, Django, PostgreSQL, and Docker — automating ingestion, cleaning, and multi-level processing workflows</li>
            <li>Implemented statistical methods including min-max scaling, outlier detection, peak detection, and data drift analysis</li>
            <li>Technical co-lead on a Federated Data Portal for the European Environmental Research Infrastructures Consortium</li>
            <li>Contributed to a Python statistical library (<a href="https://autom8qc.readthedocs.io/en/latest/" target="_blank" rel="noopener noreferrer" class="text-[#7B35E4] hover:underline">autom8qc</a>), co-authored scientific papers, presented at EGU Vienna</li>
          </ul>
        </div>
        <div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Full Stack Software Engineer</h3>
            <span class="font-mono text-xs text-[#6b6b80]">2017 — 2019</span>
          </div>
          <p class="text-[#7B35E4] text-sm mb-2">I2S Insurance Knowledge · Porto</p>
          <p class="text-[#6b6b80] text-sm">Implemented features and maintained a life insurance product using Java, Spring Boot, Angular, and microservices. Migrated a large portion of the legacy codebase to Java 8.</p>
        </div>
        <div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Full Stack Software Engineer</h3>
            <span class="font-mono text-xs text-[#6b6b80]">2015 — 2017</span>
          </div>
          <p class="text-[#7B35E4] text-sm mb-2">PrimeIT · Porto</p>
          <p class="text-[#6b6b80] text-sm">Developed business logic and frontend for a fraud detection product using Java, JavaScript, and OracleDB.</p>
        </div>
        <div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-[#e8e8f0] font-medium">Full Stack Software Engineer</h3>
            <span class="font-mono text-xs text-[#6b6b80]">2014 — 2015</span>
          </div>
          <p class="text-[#7B35E4] text-sm mb-2">Altice Labs · Aveiro</p>
          <p class="text-[#6b6b80] text-sm">Developed and maintained four TelCo projects managing the lifecycle of a CSP, using MongoDB, ElasticSearch, Ruby on Rails, and JavaScript.</p>
        </div>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="font-mono text-xs uppercase tracking-widest text-[#6b6b80] mb-6">Education</h2>
      <div class="border-l border-[#1e1e2a] pl-6 flex flex-col gap-6">
        <div>
          <h3 class="text-[#e8e8f0] font-medium mb-1">MSc Artificial Intelligence</h3>
          <p class="text-[#7B35E4] text-sm mb-1">University of Leeds</p>
          <p class="text-[#6b6b80] text-sm">Thesis: hierarchical recurrent neural networks applied to speech processing.</p>
        </div>
        <div>
          <h3 class="text-[#e8e8f0] font-medium mb-1">Post-Graduate Certificate in Data Science</h3>
          <p class="text-[#7B35E4] text-sm">Atlântica</p>
        </div>
        <div>
          <h3 class="text-[#e8e8f0] font-medium mb-1">BSc Information Technology</h3>
          <p class="text-[#7B35E4] text-sm">Universidade de Aveiro</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-mono text-xs uppercase tracking-widest text-[#6b6b80] mb-6">Skills</h2>
      <div class="grid grid-cols-2 gap-6">
        <div>
          <h3 class="text-[#e8e8f0] text-sm font-medium mb-3">Engineering</h3>
          <ul class="text-[#6b6b80] text-sm space-y-1">
            <li>Python, Django, FastAPI</li>
            <li>PyTorch, Pandas, NLP</li>
            <li>PostgreSQL, MongoDB, SQL</li>
            <li>Docker, CI/CD, Git</li>
            <li>REST APIs, Power Automate, Azure DevOps</li>
          </ul>
        </div>
        <div>
          <h3 class="text-[#e8e8f0] text-sm font-medium mb-3">Documentation & Knowledge</h3>
          <ul class="text-[#6b6b80] text-sm space-y-1">
            <li>Docs-as-code (Docusaurus, MkDocs)</li>
            <li>Helpjuice, Confluence</li>
            <li>Content governance frameworks</li>
            <li>Information architecture</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</Base>
