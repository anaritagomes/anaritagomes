---
import Base from './Base.astro';

export interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  ogImage?: string;
}
const { title, date, description, tags, ogImage } = Astro.props;
const formatted = date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${title} — Ana Rita Gomes`} description={description} ogImage={ogImage}>
  <article class="py-20">
    <header class="mb-14 max-w-[70ch]">
      <div class="flex gap-3 mb-6 flex-wrap">
        {tags.map((t) => (
          <span class="font-mono text-xs text-[#7B35E4] border border-[#7B35E4]/30 px-2 py-0.5">
            {t}
          </span>
        ))}
      </div>
      <h1 class="text-3xl font-semibold text-[#e8e8f0] leading-tight mb-4">{title}</h1>
      <p class="text-[#6b6b80] text-sm font-mono">{formatted}</p>
    </header>

    <div class="prose prose-invert max-w-[70ch]
      prose-headings:font-semibold prose-headings:text-[#e8e8f0]
      prose-a:text-[#7B35E4] prose-a:no-underline hover:prose-a:underline
      prose-code:font-mono prose-code:text-sm
      prose-pre:bg-[#0a0a0a] prose-pre:border prose-pre:border-[#1e1e2a]">
      <slot />
    </div>
  </article>
</Base>
